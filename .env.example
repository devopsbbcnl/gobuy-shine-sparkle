# SMTP (used by server/form-api.mjs — never exposed to the browser)
#
# Resend: host smtp.resend.com, user must be exactly: resend
# Password = your Resend API key (re_...). You can set RESEND_API_KEY instead of SMTP_FROM_PASS.
# Do not leave SMTP_FROM_PASS="" if you also set SMTP_FROM_PASSWORD — empty wins first.
#
SMTP_HOST="smtp.resend.com"
SMTP_FROM_NAME="GoBuyMe | Contact <contact@notifications.gobuyme.shop>"
SMTP_FROM_EMAIL="contact@notifications.gobuyme.shop"
SMTP_FROM_PORT=465
SMTP_FROM_SECURE=true
SMTP_FROM_USER=resend
SMTP_FROM_PASS="re_your_api_key_here"
# Optional duplicates (first non-empty wins: SMTP_FROM_PASS, then SMTP_FROM_PASSWORD, then RESEND_API_KEY)
# SMTP_FROM_PASSWORD="re_your_api_key_here"
# RESEND_API_KEY="re_your_api_key_here"

# Where form notification emails are delivered (defaults to SMTP_FROM_EMAIL if unset)
FORMS_TO_EMAIL="you@yourdomain.com"

# Port for the local form API (dev: Vite proxies /api → this port)
FORM_API_PORT=8787

# Optional: full URL to the form endpoint when the SPA is not served with a proxy (e.g. static preview)
# VITE_FORM_API_URL="http://127.0.0.1:8787/api/form-submit"
